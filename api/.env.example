DATABASE_URL="postgresql://postgres:postgres@localhost:5432/imes?schema=public"
JWT_SECRET="imes-dev-secret-change-in-production"
PORT=3200

# 审批通知（可选，也可在 系统管理 → 通知配置 中填写）
APP_BASE_URL="http://localhost:5174"
DINGTALK_WEBHOOK=""
WECOM_WEBHOOK=""
FEISHU_WEBHOOK=""
SLACK_WEBHOOK=""
GENERIC_WEBHOOK=""
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
EMAIL_RECIPIENTS=""

# 文件上传（默认 auto：无云配置时走本机存储）
UPLOAD_LOCAL_ENABLED=true
UPLOAD_LOCAL_DIR=uploads
# 文件大小上限请在 系统管理 → 文件存储 中配置（图片默认 2MB）
# API_PUBLIC_URL=http://localhost:3200

# 腾讯云 COS（可选，uploadMode=cos 或 auto 且已配置时使用）
# COS_SECRETID=
# COS_SECRETKEY=
# COS_APPID=
# COS_SAFE_BUCKET=
# COS_NORMAL_BUCKET=
